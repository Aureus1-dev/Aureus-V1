{
  "name": "aureus-v1",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "postinstall": "prisma generate",
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:env": "tsx apps/api/src/scripts/verify-env-cli.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prettier": "^3.3.3",
    "prisma": "^7.8.0",
    "tsx": "^4.23.1",
    "turbo": "^2.0.0",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "dotenv": "^16.0.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10",
      "@hono/node-server": ">=1.19.13"
    }
  }
}
