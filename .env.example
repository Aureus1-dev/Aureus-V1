# Copy this file to .env and fill in your credentials
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/aureus?schema=public"

# Port the API listens on. Defaults to 3000 if unset.
# PORT=3000

# NODE_ENV gates several PD-001 production-only requirements below (SMTP_HOST,
# CORS_ORIGIN, and the matching AI provider key all become REQUIRED — the app
# fails to boot without them — once NODE_ENV=production). Defaults to
# "development" if unset.
# NODE_ENV="production"

# Authentication (OAS-SEC-003). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Never reuse this value across environments; rotate on suspected compromise.
JWT_ACCESS_SECRET="replace-with-a-random-secret-at-least-32-characters"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY_DAYS=30

# CORS (PD-001). "*" is the default and is fine for local dev/CI, but is
# REQUIRED to be an explicit origin (or comma-separated list, per your CORS
# middleware config) once NODE_ENV=production — left as "*" there, the app
# refuses to boot rather than silently serving with no credentialed-CORS
# protection.
# CORS_ORIGIN="https://app.aureus.example"

# Email delivery (ADR-009). Works with any SMTP-speaking provider (SES,
# SendGrid, Postmark, etc.). Leave SMTP_HOST unset (or delete the line) to
# capture emails locally instead of delivering them — fine for local
# development, not for production: once NODE_ENV=production, SMTP_HOST is
# REQUIRED — otherwise password-reset/verification email would silently never
# arrive. FRONTEND_URL is where verification/reset links point.
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER="apikey"
# SMTP_PASSWORD="replace-with-your-smtp-credential"
SMTP_FROM_EMAIL="no-reply@aureus.app"
FRONTEND_URL="http://localhost:3001"

# AI Intelligence Engine (ADR-015). Leave AI_PROVIDER unset (or "stub") to
# use a deterministic local completion instead of calling a real AI
# provider — fine for local development/CI, not for production. Once a real
# provider is selected (either environment), its matching API key becomes
# REQUIRED (PD-001) — previously an unset key silently fell back to the stub
# provider instead of failing loudly.
# AI_PROVIDER="openai"           # "openai" | "anthropic" | "stub" (default)
# OPENAI_API_KEY="replace-with-your-openai-api-key"
# OPENAI_MODEL="gpt-4o-mini"
# ANTHROPIC_API_KEY="replace-with-your-anthropic-api-key"
# ANTHROPIC_MODEL="claude-3-5-haiku-20241022"

# API docs (PD-001). Swagger/OpenAPI at /api/docs is on by default outside
# production, OFF by default in it (a full endpoint/DTO schema dump is free
# reconnaissance value). Set to "true" to opt back in for a production
# deployment that wants the schema public.
# ENABLE_API_DOCS="false"

# AI spend limits, quotas, and emergency budget controls (PR-002). Checked
# before every provider call; defaults apply if unset. Set AI_EMERGENCY_STOP
# to "true" to immediately halt all AI features platform-wide (a kill
# switch — no restart required, takes effect on the next request).
# AI_EMERGENCY_STOP="false"
# AI_GLOBAL_DAILY_BUDGET_USD="50"    # platform-wide ceiling, rolling 24h
# AI_USER_DAILY_BUDGET_USD="2"       # per-member ceiling, rolling 24h

# Voice Domain (ADR-016). Reuses OPENAI_API_KEY above — no separate
# credential. Leave unset to use the deterministic stub voice provider
# (safe for local development/CI).
# VOICE_MODEL="gpt-4o-realtime-preview"
# VOICE_NAME="alloy"

# Admin bootstrap (PR-002). Registration always assigns MEMBER — there is
# no other path to a first administrative account. Set both, then run
# `npx prisma db seed` once against a fresh database to create the first
# SYSTEM_ADMINISTRATOR. Idempotent and safe to leave set/re-run: a no-op if
# an administrator already exists. Unset (or remove) both after first use.
# BOOTSTRAP_ADMIN_EMAIL="admin@example.com"
# BOOTSTRAP_ADMIN_PASSWORD="replace-with-a-strong-password-at-least-12-characters"

# Rate-limit storage (PD-002). Leave unset for the default in-memory
# storage — correct for a single API replica, silently wrong (per-instance
# rather than platform-wide limits) the moment there's more than one. Set
# once running more than one replica; docker-compose.yml already wires this
# to its own redis service.
# REDIS_URL="redis://localhost:6379"

# Database connection pool (PD-002). Defaults (10/0) match the `pg`
# driver's own defaults — only set these if you've deliberately sized them
# against your Postgres host's max_connections (or a pooler like PgBouncer
# in front of it).
# DATABASE_POOL_MAX=10
# DATABASE_POOL_MIN=0

# Error tracking (Production Stability). Leave unset to skip Sentry
# entirely — every 5xx still logs to stdout as before, it just never
# leaves the process. Set to a real Sentry DSN to also report uncaught
# 5xx exceptions and fatal bootstrap failures there.
# SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
