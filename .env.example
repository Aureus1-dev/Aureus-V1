# Copy this file to .env and fill in your credentials
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/aureus?schema=public"

# Authentication (OAS-SEC-003). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Never reuse this value across environments; rotate on suspected compromise.
JWT_ACCESS_SECRET="replace-with-a-random-secret-at-least-32-characters"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY_DAYS=30

# Email delivery (ADR-009). Works with any SMTP-speaking provider (SES,
# SendGrid, Postmark, etc.). Leave SMTP_HOST unset (or delete the line) to
# capture emails locally instead of delivering them — fine for local
# development, not for production. FRONTEND_URL is where verification/reset
# links point.
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER="apikey"
# SMTP_PASSWORD="replace-with-your-smtp-credential"
SMTP_FROM_EMAIL="no-reply@aureus.app"
FRONTEND_URL="http://localhost:3001"
