// Aureus V1 – Prisma Schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===========================================================================
// Enums
// ===========================================================================

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// Canonical roles per PA-003 (User Types & Roles) and PA-018 (Permissions & Access
// Architecture). A user may hold multiple roles simultaneously.
enum UserRole {
  MEMBER
  STEWARD
  ORGANIZATION_REPRESENTATIVE
  BUSINESS_REPRESENTATIVE
  PLATFORM_ADMINISTRATOR
  SYSTEM_ADMINISTRATOR
  AI_SERVICE_ACCOUNT
}

enum GoalStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum JourneyStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ===========================================================================
// User
// ===========================================================================

model User {
  id            String     @id @default(uuid()) @db.Uuid
  email         String // Uniqueness enforced by partial index (migration 004)
  emailVerified Boolean    @default(false)
  passwordHash  String? // Nullable: pre-existing/imported users have no credential yet
  roles         UserRole[] @default([MEMBER])
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  profile                 Profile?
  goals                   Goal[]
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  organizationMemberships OrganizationMember[]
  stewardCapacity         StewardCapacity?
  stewardshipAsMember     StewardshipRelationship[] @relation("StewardshipRelationshipMember")
  stewardshipAsSteward    StewardshipRelationship[] @relation("StewardshipRelationshipSteward")
}

// ===========================================================================
// Authentication & Identity Access Management
// (OAS-SEC-003, PA-018 — Identity lifecycle, credential protection)
// ===========================================================================

// Refresh tokens are stored hashed (never plaintext) and rotated on use.
model RefreshToken {
  id                  String    @id @default(uuid()) @db.Uuid
  tokenHash           String    @unique
  userId              String    @db.Uuid
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt           DateTime
  revokedAt           DateTime?
  replacedByTokenHash String?
  createdAt           DateTime  @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ===========================================================================
// Profile
// ===========================================================================

model Profile {
  id          String    @id @default(uuid()) @db.Uuid
  displayName String?
  bio         String?
  avatarUrl   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ===========================================================================
// Goal  —  User has many Goals
// ===========================================================================

model Goal {
  id        String     @id @default(uuid()) @db.Uuid
  title     String
  status    GoalStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?

  userId  String   @db.Uuid
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  journey Journey?

  @@index([userId])
}

// ===========================================================================
// Journey  —  Goal has one Journey
// ===========================================================================

model Journey {
  id        String        @id @default(uuid()) @db.Uuid
  title     String
  status    JourneyStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?

  goalId     String      @unique @db.Uuid
  goal       Goal        @relation(fields: [goalId], references: [id], onDelete: Cascade)
  milestones Milestone[]
}

// ===========================================================================
// Milestone  —  Journey has many Milestones
// ===========================================================================

model Milestone {
  id        String          @id @default(uuid()) @db.Uuid
  title     String
  status    MilestoneStatus @default(PENDING)
  position  Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  deletedAt DateTime?

  journeyId String  @db.Uuid
  journey   Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([journeyId])
}

// ===========================================================================
// Opportunity Engine Enums
// ===========================================================================

enum OpportunityCategory {
  EMPLOYMENT
  EDUCATION
  SCHOLARSHIP
  GRANT
  GOVERNMENT_BENEFIT
  HOUSING
  FINANCIAL_ASSISTANCE
  BANKING_INCENTIVE
  CREDIT_BUILDING
  BUSINESS
  VOLUNTEER
  COMMUNITY_PROGRAM
  HEALTH_WELLNESS
  OTHER
}

enum BenefitType {
  JOB
  GRANT
  SCHOLARSHIP
  LOAN
  BENEFIT
  HOUSING
  CREDIT
  TRAINING
  VOLUNTEER
  COMMUNITY
  HEALTH
  OTHER
}

enum OpportunityStatus {
  DRAFT
  ACTIVE
  EXPIRED
  ARCHIVED
}

enum VerificationStatus {
  DRAFT
  PENDING_REVIEW
  VERIFIED
  REJECTED
  ARCHIVED
}

enum SourceType {
  ADMIN_ENTRY
  ORGANIZATION_SUBMISSION
  BUSINESS_SUBMISSION
  EXTERNAL_SOURCE
}

enum TrackingStatus {
  SAVED
  APPLYING
  APPLIED
  RECEIVED
  NOT_INTERESTED
}

// ===========================================================================
// Task  —  Milestone has many Tasks
// ===========================================================================

model Task {
  id        String       @id @default(uuid()) @db.Uuid
  title     String
  status    TaskStatus   @default(PENDING)
  priority  TaskPriority @default(MEDIUM)
  position  Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?

  milestoneId String    @db.Uuid
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@index([milestoneId])
}

// ===========================================================================
// Opportunity  —  Core Opportunity Intelligence Engine model
// ===========================================================================

model Opportunity {
  id             String  @id @default(uuid()) @db.Uuid
  sequenceNumber Int     @unique @default(autoincrement())
  opportunityRef String? @unique // AUR-OPP-000001, set after insert

  title            String
  shortDescription String
  fullDescription  String
  category         OpportunityCategory
  tags             String[]            @default([])

  provider          String
  officialSourceUrl String
  applicationUrl    String?
  location          String?
  country           String?
  state             String?

  eligibilityRules String
  benefitType      BenefitType
  benefitAmount    String?
  deadline         DateTime?

  status             OpportunityStatus  @default(DRAFT)
  verificationStatus VerificationStatus @default(DRAFT)
  rejectionReason    String?

  confidenceScore Float @default(0)
  freshnessScore  Float @default(0)

  datePublished    DateTime?
  dateLastVerified DateTime?

  sourceName String
  sourceUrl  String?
  sourceType SourceType @default(ADMIN_ENTRY)

  submittedById   String    @db.Uuid
  createdById     String    @db.Uuid
  lastUpdatedById String    @db.Uuid
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  savedBy                    SavedOpportunity[]
  stewardshipRecommendations StewardshipRecommendation[]

  @@index([category])
  @@index([verificationStatus])
  @@index([status])
  @@index([benefitType])
  @@index([deadline])
  @@index([createdAt])
}

// ===========================================================================
// SavedOpportunity  —  Members save / favorite / track opportunities
// ===========================================================================

model SavedOpportunity {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @db.Uuid
  opportunityId  String         @db.Uuid
  isFavorite     Boolean        @default(false)
  trackingStatus TrackingStatus @default(SAVED)
  notes          String?
  savedAt        DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([userId, opportunityId])
  @@index([userId])
  @@index([opportunityId])
}

// ===========================================================================
// UserInterest  —  Recommendation foundation: preferred categories
// ===========================================================================

model UserInterest {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @db.Uuid
  category  OpportunityCategory
  createdAt DateTime            @default(now())

  @@unique([userId, category])
  @@index([userId])
}

// ===========================================================================
// Resource Directory Enums (PA-014)
// ===========================================================================

enum ResourceCategory {
  GOVERNMENT_AGENCY
  NONPROFIT_ORGANIZATION
  COMMUNITY_ORGANIZATION
  EDUCATIONAL_INSTITUTION
  HEALTHCARE_PROVIDER
  FINANCIAL_SERVICES
  LEGAL_SERVICES
  HOUSING_RESOURCES
  EMPLOYMENT_SERVICES
  BUSINESS_SUPPORT
  TECHNOLOGY_TOOLS
  MENTAL_HEALTH_WELLNESS
  OTHER
}

// What kind of thing the listing represents (PA-014: "organizations, programs,
// services, professionals, tools, and community resources").
enum ResourceType {
  ORGANIZATION
  PROGRAM
  SERVICE
  PROFESSIONAL
  TOOL
  COMMUNITY_RESOURCE
  OTHER
}

enum ResourceStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

// ===========================================================================
// Resource  —  Core Resource Directory model (PA-014)
// ===========================================================================

model Resource {
  id             String  @id @default(uuid()) @db.Uuid
  sequenceNumber Int     @unique @default(autoincrement())
  resourceRef    String? @unique // AUR-RES-000001, set after insert

  title            String
  shortDescription String
  fullDescription  String
  category         ResourceCategory
  resourceType     ResourceType
  tags             String[]         @default([])

  organizationName  String
  officialSourceUrl String
  contactName       String?
  contactEmail      String?
  contactPhone      String?

  location String?
  country  String?
  state    String?
  city     String?
  isRemote Boolean @default(false)

  eligibilityNotes String?

  status             ResourceStatus     @default(DRAFT)
  verificationStatus VerificationStatus @default(DRAFT)
  rejectionReason    String?

  confidenceScore Float @default(0)
  freshnessScore  Float @default(0)

  datePublished    DateTime?
  dateLastVerified DateTime?

  sourceName String
  sourceUrl  String?
  sourceType SourceType @default(ADMIN_ENTRY)

  // The user (Organization/Business representative, Steward, or Admin) who
  // manages this listing. Always the creator at insert time; Steward/Admin
  // may edit any listing regardless of ownerId (PA-018 role-based access).
  ownerId         String    @db.Uuid
  submittedById   String    @db.Uuid
  createdById     String    @db.Uuid
  lastUpdatedById String    @db.Uuid
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  savedBy                    SavedResource[]
  stewardshipRecommendations StewardshipRecommendation[]

  @@index([category])
  @@index([resourceType])
  @@index([verificationStatus])
  @@index([status])
  @@index([ownerId])
  @@index([country])
  @@index([createdAt])
}

// ===========================================================================
// SavedResource  —  Members bookmark resources for later
// ===========================================================================

model SavedResource {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  resourceId String   @db.Uuid
  isFavorite Boolean  @default(false)
  notes      String?
  savedAt    DateTime @default(now())
  updatedAt  DateTime @updatedAt

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([userId])
  @@index([resourceId])
}

// ===========================================================================
// Business Portal Enums (PA-011)
// ===========================================================================

enum OrganizationType {
  BUSINESS
  NONPROFIT
  EDUCATIONAL_INSTITUTION
  GOVERNMENT_AGENCY
  COMMUNITY_ORGANIZATION
  STRATEGIC_PARTNER
}

enum OrganizationStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum OrganizationMemberRole {
  ADMIN
  MEMBER
}

// ===========================================================================
// Organization  —  Core Business Portal model (PA-011)
// ===========================================================================

model Organization {
  id              String  @id @default(uuid()) @db.Uuid
  sequenceNumber  Int     @unique @default(autoincrement())
  organizationRef String? @unique // AUR-ORG-000001, set after insert

  name             String
  shortDescription String
  fullDescription  String
  organizationType OrganizationType

  websiteUrl   String
  contactEmail String?
  contactPhone String?

  location String?
  country  String?
  state    String?
  city     String?

  status             OrganizationStatus @default(DRAFT)
  verificationStatus VerificationStatus @default(DRAFT)
  rejectionReason    String?

  datePublished    DateTime?
  dateLastVerified DateTime?

  createdById     String    @db.Uuid
  lastUpdatedById String    @db.Uuid
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  members OrganizationMember[]

  @@index([organizationType])
  @@index([verificationStatus])
  @@index([status])
  @@index([country])
  @@index([createdAt])
}

// ===========================================================================
// OrganizationMember  —  Verified representatives acting on an Organization's
// behalf (PA-011). ADMIN manages the org profile and membership; MEMBER is a
// recognized representative without membership-management authority.
// ===========================================================================

model OrganizationMember {
  id             String                 @id @default(uuid()) @db.Uuid
  organizationId String                 @db.Uuid
  userId         String                 @db.Uuid
  role           OrganizationMemberRole @default(MEMBER)
  createdAt      DateTime               @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

// ===========================================================================
// Stewardship System Enums (PA-012)
// ===========================================================================

enum StewardshipRelationshipStatus {
  PENDING
  ACTIVE
  ENDED
}

// How a relationship came to exist. AI_RECOMMENDATION always lands in
// PENDING — the canonical product decision is that AI may recommend a
// steward but may never automatically assign one.
enum StewardshipRelationshipOrigin {
  MEMBER_REQUEST
  AI_RECOMMENDATION
  ORGANIZATION_ASSIGNMENT
  ADMIN_ASSIGNMENT
}

enum StewardshipEndReason {
  MEMBER_REQUEST
  STEWARD_RESIGNATION
  ORGANIZATION_REASSIGNMENT
  ADMIN_REASSIGNMENT
  STEWARD_INACTIVITY
}

enum StewardshipNoteVisibility {
  PRIVATE
  SHARED
}

enum StewardshipTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum StewardshipRecommendationType {
  OPPORTUNITY
  RESOURCE
}

enum StewardshipEscalationSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum StewardshipEscalationStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ===========================================================================
// StewardCapacity  —  Configurable per-steward active-member ceiling
// (PA-012). The default (25) lives exactly once, here, as the Prisma column
// default — application code never hardcodes it; a lazily-created row is
// upserted with this default the first time a steward's capacity matters.
// ===========================================================================

model StewardCapacity {
  id               String   @id @default(uuid()) @db.Uuid
  stewardId        String   @unique @db.Uuid
  steward          User     @relation(fields: [stewardId], references: [id], onDelete: Cascade)
  maxActiveMembers Int      @default(25)
  updatedById      String   @db.Uuid
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ===========================================================================
// StewardshipRelationship  —  Core steward<->member pairing and its full
// lifecycle history (PA-012). A steward is a guide, not an owner: rows are
// never deleted and never mutated back to an earlier state once ENDED —
// reassignment ends one row and creates another, preserving complete history.
// ===========================================================================

model StewardshipRelationship {
  id String @id @default(uuid()) @db.Uuid

  memberId String @db.Uuid
  member   User   @relation("StewardshipRelationshipMember", fields: [memberId], references: [id], onDelete: Cascade)

  // Nullable: a PENDING relationship created by a member's generic request
  // may not yet name a specific steward.
  stewardId String? @db.Uuid
  steward   User?   @relation("StewardshipRelationshipSteward", fields: [stewardId], references: [id], onDelete: Cascade)

  status StewardshipRelationshipStatus @default(PENDING)
  origin StewardshipRelationshipOrigin

  // Actor-audit pointers (who requested/assigned/recommended this), loose
  // UUID references with no FK — mirrors Resource/Opportunity's ownerId-style
  // audit fields (ADR-006 §3), distinct from memberId/stewardId above, which
  // are the real relationship parties and carry real FKs (ADR-010 Decision 3).
  requestedById            String? @db.Uuid
  assignedById             String? @db.Uuid
  assignedByOrganizationId String? @db.Uuid
  recommendedById          String? @db.Uuid

  endReason StewardshipEndReason?
  endedById String?               @db.Uuid
  endedAt   DateTime?

  activatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes           StewardshipNote[]
  tasks           StewardshipTask[]
  recommendations StewardshipRecommendation[]
  escalations     StewardshipEscalation[]

  @@index([memberId])
  @@index([stewardId])
  @@index([status])
}

// ===========================================================================
// StewardshipNote  —  Steward-authored notes on a relationship. PRIVATE by
// default (least privilege); only SHARED notes are ever visible to the
// member (PA-012 Member Experience / Steward Authority boundaries).
// ===========================================================================

model StewardshipNote {
  id             String                    @id @default(uuid()) @db.Uuid
  relationshipId String                    @db.Uuid
  relationship   StewardshipRelationship   @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  authorId       String                    @db.Uuid
  content        String
  visibility     StewardshipNoteVisibility @default(PRIVATE)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@index([relationshipId])
}

// ===========================================================================
// StewardshipTask  —  Steward-created follow-up tasks for a member (PA-012).
// Distinct from the member's own Journey Engine Task: this is authored by
// the steward, not owned by the member, and is visible to the member as a
// read-only "assigned task."
// ===========================================================================

model StewardshipTask {
  id             String                  @id @default(uuid()) @db.Uuid
  relationshipId String                  @db.Uuid
  relationship   StewardshipRelationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  status         StewardshipTaskStatus   @default(PENDING)
  dueDate        DateTime?
  createdById    String                  @db.Uuid
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([relationshipId])
}

// ===========================================================================
// StewardshipRecommendation  —  A steward recommends an Opportunity or a
// Resource to a member (PA-012). Exactly one of opportunityId/resourceId is
// set, enforced in the service layer (matches `type`).
// ===========================================================================

model StewardshipRecommendation {
  id             String                        @id @default(uuid()) @db.Uuid
  relationshipId String                        @db.Uuid
  relationship   StewardshipRelationship       @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  type           StewardshipRecommendationType

  opportunityId String?      @db.Uuid
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  resourceId    String?      @db.Uuid
  resource      Resource?    @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  note        String?
  createdById String   @db.Uuid
  createdAt   DateTime @default(now())

  @@index([relationshipId])
  @@index([opportunityId])
  @@index([resourceId])
}

// ===========================================================================
// StewardshipEscalation  —  Steward-raised issue requiring human review
// (PA-012). An internal accountability record, not exposed to members —
// "Escalate issues" is listed under Steward Authority, not Member Experience.
// ===========================================================================

model StewardshipEscalation {
  id              String                        @id @default(uuid()) @db.Uuid
  relationshipId  String                        @db.Uuid
  relationship    StewardshipRelationship       @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  title           String
  description     String
  severity        StewardshipEscalationSeverity @default(MEDIUM)
  status          StewardshipEscalationStatus   @default(OPEN)
  raisedById      String                        @db.Uuid
  resolvedById    String?                       @db.Uuid
  resolutionNotes String?
  createdAt       DateTime                      @default(now())
  resolvedAt      DateTime?

  @@index([relationshipId])
  @@index([status])
}
