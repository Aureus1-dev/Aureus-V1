// Aureus V1 – Prisma Schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===========================================================================
// Enums
// ===========================================================================

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// Canonical roles per PA-003 (User Types & Roles) and PA-018 (Permissions & Access
// Architecture). A user may hold multiple roles simultaneously.
enum UserRole {
  MEMBER
  STEWARD
  ORGANIZATION_REPRESENTATIVE
  BUSINESS_REPRESENTATIVE
  PLATFORM_ADMINISTRATOR
  SYSTEM_ADMINISTRATOR
  AI_SERVICE_ACCOUNT
}

enum GoalStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum JourneyStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// A current life season, not a demographic classification (WO-030 Founder
// Decision #9). No season is ranked above another; member-selected,
// optional, and changeable at any time.
enum SeasonOfLife {
  STUDENT
  EARLY_CAREER
  YOUNG_FAMILY
  ESTABLISHED_CAREER
  MID_LIFE_TRANSITION
  EMPTY_NEST
  RETIRED
  OTHER
}

// ===========================================================================
// User
// ===========================================================================

model User {
  id            String     @id @default(uuid()) @db.Uuid
  email         String // Uniqueness enforced by partial index (migration 004)
  emailVerified Boolean    @default(false)
  passwordHash  String? // Nullable: pre-existing/imported users have no credential yet
  roles         UserRole[] @default([MEMBER])
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  profile                 Profile?
  goals                   Goal[]
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  organizationMemberships OrganizationMember[]
  stewardCapacity         StewardCapacity?
  stewardshipAsMember     StewardshipRelationship[] @relation("StewardshipRelationshipMember")
  stewardshipAsSteward    StewardshipRelationship[] @relation("StewardshipRelationshipSteward")
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  announcementsAsSteward  Announcement[]            @relation("AnnouncementSteward")
  conversationMemberships ConversationParticipant[]
  sentMessages            Message[]
  enrollments             Enrollment[]
  certifications          Certification[]
  aiConversations         AiConversation[]
  aiRequests              AiRequest[]
  aiRecommendations       AiRecommendation[]
  podMemberships          PodMembership[]
  podEventRsvps           PodEventRsvp[]
  podRequests             PodRequest[]
  podInvitationsReceived  PodInvitation[]           @relation("PodInvitationInvitee")
}

// ===========================================================================
// Authentication & Identity Access Management
// (OAS-SEC-003, PA-018 — Identity lifecycle, credential protection)
// ===========================================================================

// Refresh tokens are stored hashed (never plaintext) and rotated on use.
model RefreshToken {
  id                  String    @id @default(uuid()) @db.Uuid
  tokenHash           String    @unique
  userId              String    @db.Uuid
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt           DateTime
  revokedAt           DateTime?
  replacedByTokenHash String?
  createdAt           DateTime  @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ===========================================================================
// Profile
// ===========================================================================

model Profile {
  id          String    @id @default(uuid()) @db.Uuid
  displayName String?
  bio         String?
  avatarUrl   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Pods matching signals (WO-030, Founder Decisions #7-#9). Every field
  // below is optional, member-owned, editable, and purpose-bound — the
  // Institution learns about a person because they chose to share, never
  // because a field was required or defaulted.
  city                 String? // coarse location — Founder Decision #8, never precise geolocation
  region               String?
  stateProvince        String?
  country              String?
  localAreaDescription String? // free text: "describe the community area you consider local to you"
  profession           String?
  seasonOfLife         SeasonOfLife? // Founder Decision #9 — a current season, never a permanent category
  availabilityNotes    String?
  preferredLanguage    String?
  faithPreference      String? // voluntary only; never defaulted, never required (§6 privacy model)

  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ===========================================================================
// Goal  —  User has many Goals
// ===========================================================================

model Goal {
  id        String     @id @default(uuid()) @db.Uuid
  title     String
  status    GoalStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?

  userId  String   @db.Uuid
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  journey Journey?

  @@index([userId])
}

// ===========================================================================
// Journey  —  Goal has one Journey
// ===========================================================================

model Journey {
  id        String        @id @default(uuid()) @db.Uuid
  title     String
  status    JourneyStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?

  goalId     String      @unique @db.Uuid
  goal       Goal        @relation(fields: [goalId], references: [id], onDelete: Cascade)
  milestones Milestone[]
}

// ===========================================================================
// Milestone  —  Journey has many Milestones
// ===========================================================================

model Milestone {
  id        String          @id @default(uuid()) @db.Uuid
  title     String
  status    MilestoneStatus @default(PENDING)
  position  Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  deletedAt DateTime?

  journeyId String  @db.Uuid
  journey   Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([journeyId])
}

// ===========================================================================
// Opportunity Engine Enums
// ===========================================================================

enum OpportunityCategory {
  EMPLOYMENT
  EDUCATION
  SCHOLARSHIP
  GRANT
  GOVERNMENT_BENEFIT
  HOUSING
  FINANCIAL_ASSISTANCE
  BANKING_INCENTIVE
  CREDIT_BUILDING
  BUSINESS
  VOLUNTEER
  COMMUNITY_PROGRAM
  HEALTH_WELLNESS
  OTHER
}

enum BenefitType {
  JOB
  GRANT
  SCHOLARSHIP
  LOAN
  BENEFIT
  HOUSING
  CREDIT
  TRAINING
  VOLUNTEER
  COMMUNITY
  HEALTH
  OTHER
}

enum OpportunityStatus {
  DRAFT
  ACTIVE
  EXPIRED
  ARCHIVED
}

enum VerificationStatus {
  DRAFT
  PENDING_REVIEW
  VERIFIED
  REJECTED
  ARCHIVED
}

enum SourceType {
  ADMIN_ENTRY
  ORGANIZATION_SUBMISSION
  BUSINESS_SUBMISSION
  EXTERNAL_SOURCE
}

enum TrackingStatus {
  SAVED
  APPLYING
  APPLIED
  RECEIVED
  NOT_INTERESTED
}

// ===========================================================================
// Task  —  Milestone has many Tasks
// ===========================================================================

model Task {
  id        String       @id @default(uuid()) @db.Uuid
  title     String
  status    TaskStatus   @default(PENDING)
  priority  TaskPriority @default(MEDIUM)
  position  Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?

  milestoneId String    @db.Uuid
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@index([milestoneId])
}

// ===========================================================================
// Opportunity  —  Core Opportunity Intelligence Engine model
// ===========================================================================

model Opportunity {
  id             String  @id @default(uuid()) @db.Uuid
  sequenceNumber Int     @unique @default(autoincrement())
  opportunityRef String? @unique // AUR-OPP-000001, set after insert

  title            String
  shortDescription String
  fullDescription  String
  category         OpportunityCategory
  tags             String[]            @default([])

  provider          String
  officialSourceUrl String
  applicationUrl    String?
  location          String?
  country           String?
  state             String?

  eligibilityRules String
  benefitType      BenefitType
  benefitAmount    String?
  deadline         DateTime?

  status             OpportunityStatus  @default(DRAFT)
  verificationStatus VerificationStatus @default(DRAFT)
  rejectionReason    String?

  confidenceScore Float @default(0)
  freshnessScore  Float @default(0)

  datePublished    DateTime?
  dateLastVerified DateTime?

  sourceName String
  sourceUrl  String?
  sourceType SourceType @default(ADMIN_ENTRY)

  submittedById   String    @db.Uuid
  createdById     String    @db.Uuid
  lastUpdatedById String    @db.Uuid
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  savedBy                    SavedOpportunity[]
  stewardshipRecommendations StewardshipRecommendation[]
  aiRecommendations          AiRecommendation[]

  @@index([category])
  @@index([verificationStatus])
  @@index([status])
  @@index([benefitType])
  @@index([deadline])
  @@index([createdAt])
}

// ===========================================================================
// SavedOpportunity  —  Members save / favorite / track opportunities
// ===========================================================================

model SavedOpportunity {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @db.Uuid
  opportunityId  String         @db.Uuid
  isFavorite     Boolean        @default(false)
  trackingStatus TrackingStatus @default(SAVED)
  notes          String?
  savedAt        DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([userId, opportunityId])
  @@index([userId])
  @@index([opportunityId])
}

// ===========================================================================
// UserInterest  —  Recommendation foundation: preferred categories
// ===========================================================================

model UserInterest {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @db.Uuid
  category  OpportunityCategory
  createdAt DateTime            @default(now())

  @@unique([userId, category])
  @@index([userId])
}

// ===========================================================================
// Resource Directory Enums (PA-014)
// ===========================================================================

enum ResourceCategory {
  GOVERNMENT_AGENCY
  NONPROFIT_ORGANIZATION
  COMMUNITY_ORGANIZATION
  EDUCATIONAL_INSTITUTION
  HEALTHCARE_PROVIDER
  FINANCIAL_SERVICES
  LEGAL_SERVICES
  HOUSING_RESOURCES
  EMPLOYMENT_SERVICES
  BUSINESS_SUPPORT
  TECHNOLOGY_TOOLS
  MENTAL_HEALTH_WELLNESS
  OTHER
}

// What kind of thing the listing represents (PA-014: "organizations, programs,
// services, professionals, tools, and community resources").
enum ResourceType {
  ORGANIZATION
  PROGRAM
  SERVICE
  PROFESSIONAL
  TOOL
  COMMUNITY_RESOURCE
  OTHER
}

enum ResourceStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

// ===========================================================================
// Resource  —  Core Resource Directory model (PA-014)
// ===========================================================================

model Resource {
  id             String  @id @default(uuid()) @db.Uuid
  sequenceNumber Int     @unique @default(autoincrement())
  resourceRef    String? @unique // AUR-RES-000001, set after insert

  title            String
  shortDescription String
  fullDescription  String
  category         ResourceCategory
  resourceType     ResourceType
  tags             String[]         @default([])

  organizationName  String
  officialSourceUrl String
  contactName       String?
  contactEmail      String?
  contactPhone      String?

  location String?
  country  String?
  state    String?
  city     String?
  isRemote Boolean @default(false)

  eligibilityNotes String?

  status             ResourceStatus     @default(DRAFT)
  verificationStatus VerificationStatus @default(DRAFT)
  rejectionReason    String?

  confidenceScore Float @default(0)
  freshnessScore  Float @default(0)

  datePublished    DateTime?
  dateLastVerified DateTime?

  sourceName String
  sourceUrl  String?
  sourceType SourceType @default(ADMIN_ENTRY)

  // The user (Organization/Business representative, Steward, or Admin) who
  // manages this listing. Always the creator at insert time; Steward/Admin
  // may edit any listing regardless of ownerId (PA-018 role-based access).
  ownerId         String    @db.Uuid
  submittedById   String    @db.Uuid
  createdById     String    @db.Uuid
  lastUpdatedById String    @db.Uuid
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  savedBy                    SavedResource[]
  stewardshipRecommendations StewardshipRecommendation[]
  aiRecommendations          AiRecommendation[]

  @@index([category])
  @@index([resourceType])
  @@index([verificationStatus])
  @@index([status])
  @@index([ownerId])
  @@index([country])
  @@index([createdAt])
}

// ===========================================================================
// SavedResource  —  Members bookmark resources for later
// ===========================================================================

model SavedResource {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  resourceId String   @db.Uuid
  isFavorite Boolean  @default(false)
  notes      String?
  savedAt    DateTime @default(now())
  updatedAt  DateTime @updatedAt

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([userId])
  @@index([resourceId])
}

// ===========================================================================
// Business Portal Enums (PA-011)
// ===========================================================================

enum OrganizationType {
  BUSINESS
  NONPROFIT
  EDUCATIONAL_INSTITUTION
  GOVERNMENT_AGENCY
  COMMUNITY_ORGANIZATION
  STRATEGIC_PARTNER
}

enum OrganizationStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum OrganizationMemberRole {
  ADMIN
  MEMBER
}

// ===========================================================================
// Organization  —  Core Business Portal model (PA-011)
// ===========================================================================

model Organization {
  id              String  @id @default(uuid()) @db.Uuid
  sequenceNumber  Int     @unique @default(autoincrement())
  organizationRef String? @unique // AUR-ORG-000001, set after insert

  name             String
  shortDescription String
  fullDescription  String
  organizationType OrganizationType

  websiteUrl   String
  contactEmail String?
  contactPhone String?

  location String?
  country  String?
  state    String?
  city     String?

  status             OrganizationStatus @default(DRAFT)
  verificationStatus VerificationStatus @default(DRAFT)
  rejectionReason    String?

  datePublished    DateTime?
  dateLastVerified DateTime?

  createdById     String    @db.Uuid
  lastUpdatedById String    @db.Uuid
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  members       OrganizationMember[]
  announcements Announcement[]
  conversations Conversation[]
  courses       Course[]

  @@index([organizationType])
  @@index([verificationStatus])
  @@index([status])
  @@index([country])
  @@index([createdAt])
}

// ===========================================================================
// OrganizationMember  —  Verified representatives acting on an Organization's
// behalf (PA-011). ADMIN manages the org profile and membership; MEMBER is a
// recognized representative without membership-management authority.
// ===========================================================================

model OrganizationMember {
  id             String                 @id @default(uuid()) @db.Uuid
  organizationId String                 @db.Uuid
  userId         String                 @db.Uuid
  role           OrganizationMemberRole @default(MEMBER)
  createdAt      DateTime               @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

// ===========================================================================
// Stewardship System Enums (PA-012)
// ===========================================================================

enum StewardshipRelationshipStatus {
  PENDING
  ACTIVE
  ENDED
}

// How a relationship came to exist. AI_RECOMMENDATION always lands in
// PENDING — the canonical product decision is that AI may recommend a
// steward but may never automatically assign one.
enum StewardshipRelationshipOrigin {
  MEMBER_REQUEST
  AI_RECOMMENDATION
  ORGANIZATION_ASSIGNMENT
  ADMIN_ASSIGNMENT
}

enum StewardshipEndReason {
  MEMBER_REQUEST
  STEWARD_RESIGNATION
  ORGANIZATION_REASSIGNMENT
  ADMIN_REASSIGNMENT
  STEWARD_INACTIVITY
}

enum StewardshipNoteVisibility {
  PRIVATE
  SHARED
}

enum StewardshipTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum StewardshipRecommendationType {
  OPPORTUNITY
  RESOURCE
}

enum StewardshipEscalationSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum StewardshipEscalationStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ===========================================================================
// StewardCapacity  —  Configurable per-steward active-member ceiling
// (PA-012). The default (25) lives exactly once, here, as the Prisma column
// default — application code never hardcodes it; a lazily-created row is
// upserted with this default the first time a steward's capacity matters.
// ===========================================================================

model StewardCapacity {
  id               String   @id @default(uuid()) @db.Uuid
  stewardId        String   @unique @db.Uuid
  steward          User     @relation(fields: [stewardId], references: [id], onDelete: Cascade)
  maxActiveMembers Int      @default(25)
  updatedById      String   @db.Uuid
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ===========================================================================
// StewardshipRelationship  —  Core steward<->member pairing and its full
// lifecycle history (PA-012). A steward is a guide, not an owner: rows are
// never deleted and never mutated back to an earlier state once ENDED —
// reassignment ends one row and creates another, preserving complete history.
// ===========================================================================

model StewardshipRelationship {
  id String @id @default(uuid()) @db.Uuid

  memberId String @db.Uuid
  member   User   @relation("StewardshipRelationshipMember", fields: [memberId], references: [id], onDelete: Cascade)

  // Nullable: a PENDING relationship created by a member's generic request
  // may not yet name a specific steward.
  stewardId String? @db.Uuid
  steward   User?   @relation("StewardshipRelationshipSteward", fields: [stewardId], references: [id], onDelete: Cascade)

  status StewardshipRelationshipStatus @default(PENDING)
  origin StewardshipRelationshipOrigin

  // Actor-audit pointers (who requested/assigned/recommended this), loose
  // UUID references with no FK — mirrors Resource/Opportunity's ownerId-style
  // audit fields (ADR-006 §3), distinct from memberId/stewardId above, which
  // are the real relationship parties and carry real FKs (ADR-010 Decision 3).
  requestedById            String? @db.Uuid
  assignedById             String? @db.Uuid
  assignedByOrganizationId String? @db.Uuid
  recommendedById          String? @db.Uuid

  endReason StewardshipEndReason?
  endedById String?               @db.Uuid
  endedAt   DateTime?

  activatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes           StewardshipNote[]
  tasks           StewardshipTask[]
  recommendations StewardshipRecommendation[]
  escalations     StewardshipEscalation[]
  conversation    Conversation?

  @@index([memberId])
  @@index([stewardId])
  @@index([status])
}

// ===========================================================================
// StewardshipNote  —  Steward-authored notes on a relationship. PRIVATE by
// default (least privilege); only SHARED notes are ever visible to the
// member (PA-012 Member Experience / Steward Authority boundaries).
// ===========================================================================

model StewardshipNote {
  id             String                    @id @default(uuid()) @db.Uuid
  relationshipId String                    @db.Uuid
  relationship   StewardshipRelationship   @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  authorId       String                    @db.Uuid
  content        String
  visibility     StewardshipNoteVisibility @default(PRIVATE)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@index([relationshipId])
}

// ===========================================================================
// StewardshipTask  —  Steward-created follow-up tasks for a member (PA-012).
// Distinct from the member's own Journey Engine Task: this is authored by
// the steward, not owned by the member, and is visible to the member as a
// read-only "assigned task."
// ===========================================================================

model StewardshipTask {
  id             String                  @id @default(uuid()) @db.Uuid
  relationshipId String                  @db.Uuid
  relationship   StewardshipRelationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  status         StewardshipTaskStatus   @default(PENDING)
  dueDate        DateTime?
  createdById    String                  @db.Uuid
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([relationshipId])
}

// ===========================================================================
// StewardshipRecommendation  —  A steward recommends an Opportunity or a
// Resource to a member (PA-012). Exactly one of opportunityId/resourceId is
// set, enforced in the service layer (matches `type`).
// ===========================================================================

model StewardshipRecommendation {
  id             String                        @id @default(uuid()) @db.Uuid
  relationshipId String                        @db.Uuid
  relationship   StewardshipRelationship       @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  type           StewardshipRecommendationType

  opportunityId String?      @db.Uuid
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  resourceId    String?      @db.Uuid
  resource      Resource?    @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  note        String?
  createdById String   @db.Uuid
  createdAt   DateTime @default(now())

  @@index([relationshipId])
  @@index([opportunityId])
  @@index([resourceId])
}

// ===========================================================================
// StewardshipEscalation  —  A confidential request for additional
// stewardship, never an accusation, disciplinary record, or presumption of
// wrongdoing (PA-012; reframed constitutionally by WO-030 Founder Decision
// #4, which now governs this model platform-wide). Not exposed to the
// member concerned — "Escalate issues" is listed under Steward Authority,
// not Member Experience. Exactly one of relationshipId/podId is set,
// mirroring StewardshipRecommendation's real-nullable-FK-per-target shape;
// enforced in the service layer. A Pod escalation may be raised by any
// ACTIVE Pod member, not only the Pod Steward, so a concern about a
// Steward's own conduct is never filterable by that Steward.
// ===========================================================================

model StewardshipEscalation {
  id              String                        @id @default(uuid()) @db.Uuid
  relationshipId  String?                       @db.Uuid
  relationship    StewardshipRelationship?      @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  podId           String?                       @db.Uuid
  pod             Pod?                          @relation(fields: [podId], references: [id], onDelete: Cascade)
  title           String
  description     String
  severity        StewardshipEscalationSeverity @default(MEDIUM)
  status          StewardshipEscalationStatus   @default(OPEN)
  raisedById      String                        @db.Uuid
  resolvedById    String?                       @db.Uuid
  resolutionNotes String?
  createdAt       DateTime                      @default(now())
  resolvedAt      DateTime?

  @@index([relationshipId])
  @@index([podId])
  @@index([status])
}

// ===========================================================================
// Communication System Enums (PA-015)
// ===========================================================================

// The coarse "what is this about" classification, doubling as the
// integration-source domain (Notification.type carries the fine-grained,
// free-text event key so future domains never need an enum migration to add
// a new notification kind — see ADR-012 Decision 2).
enum NotificationCategory {
  ACCOUNT
  STEWARDSHIP
  JOURNEY
  OPPORTUNITY
  RESOURCE
  ORGANIZATION
  ANNOUNCEMENT
  MESSAGE
  SYSTEM
  ACADEMY
  POD
  AI_GUIDANCE
  KNOWLEDGE
}

enum DeliveryChannel {
  IN_APP
  EMAIL
}

// DELIVERED is only ever set for IN_APP (persistence itself is the honest
// delivery confirmation); EMAIL tops out at SENT — there is no delivery
// webhook yet, so EMAIL never fabricates DELIVERED (ADR-012 Decision 6).
enum DeliveryStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  SKIPPED
}

enum AnnouncementScope {
  PLATFORM
  ORGANIZATION
  ROLE
  STEWARD_MEMBERS
}

enum AnnouncementStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  EXPIRED
  ARCHIVED
}

enum ConversationType {
  STEWARDSHIP
  ORGANIZATION
  POD
}

// Reserved for forward compatibility with a future external delivery
// channel; every V1 message is in-app and synchronously persisted, so SENT
// is the only value ever actually written (ADR-012 Decision 5).
enum MessageStatus {
  SENT
  DELIVERED
  FAILED
}

// ===========================================================================
// Notification  —  In-app notification delivered to a single recipient
// (PA-015). `category` is the coarse classification; `type` is a free-text,
// dot-namespaced event key (e.g. "stewardship.relationship.activated") so
// any current or future domain can mint new notification kinds without a
// schema migration. `dedupeKey`, when supplied by the calling domain, gives
// the integration point (NotificationsService.notify()) DB-enforced
// idempotency against retried domain-event delivery.
// ===========================================================================

model Notification {
  id          String               @id @default(uuid()) @db.Uuid
  recipientId String               @db.Uuid
  recipient   User                 @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  category    NotificationCategory
  type        String
  title       String
  body        String
  data        Json?
  actorId     String?              @db.Uuid
  dedupeKey   String?
  readAt      DateTime?
  archivedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime             @default(now())

  deliveries NotificationDelivery[]

  @@unique([recipientId, dedupeKey])
  @@index([recipientId, readAt])
  @@index([recipientId, createdAt])
  @@index([category])
}

// ===========================================================================
// NotificationDelivery  —  Per-channel delivery attempt/status record for a
// Notification (PA-015 §Delivery Tracking). The unique constraint on
// [notificationId, channel] is what makes a repeated send request a no-op
// rather than a duplicate send (ADR-012 Decision 6).
// ===========================================================================

model NotificationDelivery {
  id             String          @id @default(uuid()) @db.Uuid
  notificationId String          @db.Uuid
  notification   Notification    @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  channel        DeliveryChannel
  status         DeliveryStatus  @default(PENDING)
  attempts       Int             @default(0)
  lastAttemptAt  DateTime?
  deliveredAt    DateTime?
  failureReason  String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([notificationId, channel])
  @@index([status])
}

// ===========================================================================
// NotificationPreference  —  Per-user, per-category channel preferences
// (PA-015 §Communication Preferences). Absence of a row for a given
// [userId, category] means the secure default (both channels enabled)
// applies — rows only exist once a user has customized a category. SYSTEM
// category's inAppEnabled cannot be set false (enforced in the service, not
// the schema) — the platform's one non-disableable channel, per PA-015's
// "Override member communication preferences except for critical platform
// or safety notifications" boundary. digestEnabled/quietHours* are a stored
// foundation for a future scheduled-digest capability; nothing reads them
// yet (ADR-012 Decision 4).
// ===========================================================================

model NotificationPreference {
  id              String               @id @default(uuid()) @db.Uuid
  userId          String               @db.Uuid
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        NotificationCategory
  inAppEnabled    Boolean              @default(true)
  emailEnabled    Boolean              @default(true)
  digestEnabled   Boolean              @default(false)
  quietHoursStart Int?
  quietHoursEnd   Int?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([userId, category])
}

// ===========================================================================
// Announcement  —  Platform/organization/role/steward-audience broadcast
// (PA-015 §Announcements). Exactly one of organizationId/targetRole/
// stewardId is set, matching `scope` (enforced in the service layer, mirrors
// StewardshipRecommendation's type/target pairing). Publishing fans out one
// Notification per resolved recipient (ADR-012 Decision 3). `isCritical`
// bypasses recipient ANNOUNCEMENT-category preference filtering for the
// in-app channel only — the schema-level mechanism for PA-015's "critical
// platform or safety notifications" carve-out.
// ===========================================================================

model Announcement {
  id             String             @id @default(uuid()) @db.Uuid
  title          String
  body           String
  scope          AnnouncementScope
  organizationId String?            @db.Uuid
  organization   Organization?      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  targetRole     UserRole?
  stewardId      String?            @db.Uuid
  steward        User?              @relation("AnnouncementSteward", fields: [stewardId], references: [id], onDelete: Cascade)
  status         AnnouncementStatus @default(DRAFT)
  isCritical     Boolean            @default(false)
  scheduledFor   DateTime?
  publishedAt    DateTime?
  expiresAt      DateTime?
  archivedAt     DateTime?
  authorId       String             @db.Uuid
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([scope])
  @@index([status])
  @@index([organizationId])
}

// ===========================================================================
// Conversation  —  A messaging thread (PA-015 §Direct and Contextual
// Messaging). STEWARDSHIP conversations are 1:1 with a StewardshipRelationship
// (the unique `relationshipId` makes "start a conversation" idempotent —
// get-or-create by relationship, never a duplicate thread per relationship).
// ORGANIZATION conversations scope participants to representatives of the
// same Organization (no member-enrollment model exists yet — mirrors
// ADR-011 Decision 8's documented Business Portal scoping limitation).
// POD conversations are 1:1 with a Pod (unique `podId`, same get-or-create
// idempotency as STEWARDSHIP) with every ACTIVE PodMembership seated as a
// participant — the exact N-participant extension ADR-012 Decision 8
// pre-declared for this moment (WO-030).
// ===========================================================================

model Conversation {
  id             String                   @id @default(uuid()) @db.Uuid
  type           ConversationType
  relationshipId String?                  @unique @db.Uuid
  relationship   StewardshipRelationship? @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  organizationId String?                  @db.Uuid
  organization   Organization?            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  podId          String?                  @unique @db.Uuid
  pod            Pod?                     @relation(fields: [podId], references: [id], onDelete: Cascade)
  lastMessageAt  DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@index([organizationId])
}

// ===========================================================================
// ConversationParticipant  —  Explicit participant whitelist for a
// Conversation. Authorization always checks membership in this table, never
// re-derives it from the Conversation's type-specific scoping fields at
// message-send time — defense in depth if a relationship/org membership
// later changes shape (ADR-012 Decision 7). `lastReadAt` is the read-state
// foundation ("Message status" requirement) without per-message receipts.
// ===========================================================================

model ConversationParticipant {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @db.Uuid
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String       @db.Uuid
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime?
  joinedAt       DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

// ===========================================================================
// Message  —  A single message within a Conversation. `senderId` is always
// derived from the authenticated JWT, never trusted from the request body.
// ===========================================================================

model Message {
  id             String        @id @default(uuid()) @db.Uuid
  conversationId String        @db.Uuid
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String        @db.Uuid
  sender         User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body           String
  status         MessageStatus @default(SENT)
  createdAt      DateTime      @default(now())
  deletedAt      DateTime?

  @@index([conversationId, createdAt])
  @@index([senderId])
}

// ===========================================================================
// Knowledge System Enums (PA-013)
// ===========================================================================

enum KnowledgeCategory {
  ARTICLE
  GUIDE
  POLICY
  BEST_PRACTICE
  RESEARCH_SUMMARY
  FAQ
  TRAINING_MATERIAL
  INSTITUTIONAL_DOCUMENTATION
  REFERENCE_RESOURCE
}

enum KnowledgeArticleStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

// ===========================================================================
// KnowledgeArticle  —  Core Knowledge System model (PA-013). Reuses the
// shared VerificationStatus verification workflow verbatim from Resources/
// Opportunities/Organizations (PA-013 "verify information before
// publication" is the same shape of problem those domains already solved).
// `version` + KnowledgeArticleRevision together satisfy "track revisions and
// version history" — the one genuinely new capability this domain needs
// beyond the established verification-workflow pattern.
// ===========================================================================

model KnowledgeArticle {
  id             String  @id @default(uuid()) @db.Uuid
  sequenceNumber Int     @unique @default(autoincrement())
  articleRef     String? @unique // AUR-KB-000001, set after insert

  title    String
  summary  String
  content  String
  category KnowledgeCategory
  tags     String[]          @default([])

  // "Approved external sources" (PA-013 Inputs) — optional provenance link.
  sourceUrl String?

  status             KnowledgeArticleStatus @default(DRAFT)
  verificationStatus VerificationStatus     @default(DRAFT)
  rejectionReason    String?

  version Int @default(1)

  datePublished    DateTime?
  dateLastVerified DateTime?

  // Loose audit pointers (no FK), mirroring Resource.ownerId (ADR-006 §3) —
  // authorship attribution, not a relational identity.
  authorId        String    @db.Uuid
  lastUpdatedById String    @db.Uuid
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  revisions      KnowledgeArticleRevision[]
  relatedLessons Lesson[]

  @@index([category])
  @@index([verificationStatus])
  @@index([status])
  @@index([authorId])
  @@index([createdAt])
}

// ===========================================================================
// KnowledgeArticleRevision  —  A snapshot of a KnowledgeArticle's content
// immediately before a substantive edit (title/summary/content/category).
// Real FK to KnowledgeArticle: this is genuine containment, not an audit
// pointer — a revision cannot outlive its article (mirrors
// StewardshipNote/StewardshipTask's relationship to StewardshipRelationship,
// ADR-011). Articles are never hard-deleted (soft delete only), so revision
// history is preserved for the life of the platform.
// ===========================================================================

model KnowledgeArticleRevision {
  id            String            @id @default(uuid()) @db.Uuid
  articleId     String            @db.Uuid
  article       KnowledgeArticle  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  versionNumber Int
  title         String
  summary       String
  content       String
  category      KnowledgeCategory
  editedById    String            @db.Uuid
  createdAt     DateTime          @default(now())

  @@unique([articleId, versionNumber])
  @@index([articleId])
}

// ===========================================================================
// Academy Enums (PA-010)
// ===========================================================================

// Shared Draft/Active/Archived lifecycle for Course and LearningPath — the
// same shape as KnowledgeArticleStatus/ResourceStatus, named generically
// since two Academy entities share it (ADR-014).
enum AcademyContentStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum LearningDomain {
  PERSONAL_DEVELOPMENT
  FINANCIAL_LITERACY
  CAREER_READINESS
  ENTREPRENEURSHIP
  LEADERSHIP
  TECHNOLOGY_AND_AI
  HEALTH_AND_WELLBEING
  CIVIC_AND_COMMUNITY_ENGAGEMENT
  STEWARDSHIP
  MISSION_SPECIFIC_PROGRAMS
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum LessonProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum MediaType {
  VIDEO
  DOCUMENT
  IMAGE
  AUDIO
  ATTACHMENT
}

// ===========================================================================
// Course  —  Core Academy model (PA-010). Reuses the shared VerificationStatus
// verification workflow verbatim (Resources/Opportunities/Organizations/
// Knowledge — a fifth domain now sharing this pattern), plus a `version`
// counter and CourseRevision pre-edit snapshots (identical shape to
// KnowledgeArticle/KnowledgeArticleRevision, ADR-013) for "versioned
// curriculum." `organizationId` is an optional Business Portal integration
// point (attribution only — course authority remains Steward/Admin-only
// per the founder's WO-026 canonical decision, unlike Resources/Knowledge's
// broader creator set).
// ===========================================================================

model Course {
  id             String  @id @default(uuid()) @db.Uuid
  sequenceNumber Int     @unique @default(autoincrement())
  courseRef      String? @unique // AUR-CRS-000001, set after insert

  title                    String
  shortDescription         String
  fullDescription          String
  learningDomain           LearningDomain
  estimatedDurationMinutes Int?

  status             AcademyContentStatus @default(DRAFT)
  verificationStatus VerificationStatus   @default(DRAFT)
  rejectionReason    String?

  version             Int     @default(1)
  grantsCertification Boolean @default(false)

  // Optional Business Portal integration — attribution only.
  organizationId String?       @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  authorId        String    @db.Uuid
  lastUpdatedById String    @db.Uuid
  datePublished   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  modules             Module[]
  revisions           CourseRevision[]
  learningPathCourses LearningPathCourse[]
  enrollments         Enrollment[]
  certifications      Certification[]
  media               CourseMedia[]
  aiRecommendations   AiRecommendation[]

  @@index([learningDomain])
  @@index([verificationStatus])
  @@index([status])
  @@index([authorId])
  @@index([organizationId])
  @@index([createdAt])
}

model CourseRevision {
  id               String   @id @default(uuid()) @db.Uuid
  courseId         String   @db.Uuid
  course           Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  versionNumber    Int
  title            String
  shortDescription String
  fullDescription  String
  editedById       String   @db.Uuid
  createdAt        DateTime @default(now())

  @@unique([courseId, versionNumber])
  @@index([courseId])
}

// ===========================================================================
// Module / Lesson  —  A Course's structural content tree. `Lesson.
// relatedArticleId` is an optional Knowledge System integration point
// (supplementary reading), validated against a real KnowledgeArticle row.
// ===========================================================================

model Module {
  id          String   @id @default(uuid()) @db.Uuid
  courseId    String   @db.Uuid
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  description String?
  position    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lessons Lesson[]

  @@index([courseId])
}

model Lesson {
  id                       String @id @default(uuid()) @db.Uuid
  moduleId                 String @db.Uuid
  module                   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title                    String
  content                  String
  position                 Int
  estimatedDurationMinutes Int?

  relatedArticleId String?           @db.Uuid
  relatedArticle   KnowledgeArticle? @relation(fields: [relatedArticleId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  progress LessonProgress[]
  media    CourseMedia[]

  @@index([moduleId])
  @@index([relatedArticleId])
}

// ===========================================================================
// LearningPath  —  A curated, ordered sequence of Courses (PA-010). Enrollment
// and completion are Course-scoped only in this foundation, not LearningPath-
// scoped — a LearningPath is a discovery/curation structure a member browses
// and works through course-by-course; see ADR-014 for the deferred
// path-level-progress-aggregation Future Extension Point.
// ===========================================================================

model LearningPath {
  id             String  @id @default(uuid()) @db.Uuid
  sequenceNumber Int     @unique @default(autoincrement())
  pathRef        String? @unique // AUR-LP-000001, set after insert

  title            String
  shortDescription String
  fullDescription  String

  status             AcademyContentStatus @default(DRAFT)
  verificationStatus VerificationStatus   @default(DRAFT)
  rejectionReason    String?

  authorId        String    @db.Uuid
  lastUpdatedById String    @db.Uuid
  datePublished   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  pathCourses LearningPathCourse[]

  @@index([verificationStatus])
  @@index([status])
  @@index([authorId])
}

model LearningPathCourse {
  id             String       @id @default(uuid()) @db.Uuid
  learningPathId String       @db.Uuid
  learningPath   LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  courseId       String       @db.Uuid
  course         Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  position       Int
  createdAt      DateTime     @default(now())

  @@unique([learningPathId, courseId])
  @@index([learningPathId])
  @@index([courseId])
}

// ===========================================================================
// Enrollment / LessonProgress  —  A member's (or steward's) participation in
// a Course. Real FK to User: a genuine relationship, mirroring the
// StewardshipRelationship/ConversationParticipant precedent, not an audit
// pointer. `Enrollment` auto-completes when every Lesson in the Course
// reaches COMPLETED (ADR-014).
// ===========================================================================

model Enrollment {
  id       String           @id @default(uuid()) @db.Uuid
  userId   String           @db.Uuid
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId String           @db.Uuid
  course   Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  status   EnrollmentStatus @default(ACTIVE)

  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  lessonProgress LessonProgress[]

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model LessonProgress {
  id           String               @id @default(uuid()) @db.Uuid
  enrollmentId String               @db.Uuid
  enrollment   Enrollment           @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lessonId     String               @db.Uuid
  lesson       Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  status       LessonProgressStatus @default(NOT_STARTED)

  startedAt   DateTime?
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([enrollmentId, lessonId])
  @@index([enrollmentId])
  @@index([lessonId])
}

// ===========================================================================
// Certification  —  Steward certification foundation (PA-010). Auto-issued
// when a Course with `grantsCertification: true` is completed. A minimal,
// genuinely functional foundation — no renewal/expiration/external-
// verification logic yet (ADR-014 Known Limitations).
// ===========================================================================

model Certification {
  id             String   @id @default(uuid()) @db.Uuid
  sequenceNumber Int      @unique @default(autoincrement())
  userId         String   @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId       String   @db.Uuid
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  certificateRef String?  @unique // AUR-CERT-000001, set after insert
  issuedAt       DateTime @default(now())

  @@unique([userId, courseId])
  @@index([userId])
}

// ===========================================================================
// MediaAsset / CourseMedia  —  Steward Content Studio (PA-010, part of
// Academy per the founder's canonical decision, not a standalone domain).
// `storageRef` is an opaque pointer (key/URL) — a storage abstraction only;
// no cloud storage provider is implemented in this WO (ADR-014 Decision 5).
// ===========================================================================

model MediaAsset {
  id             String  @id @default(uuid()) @db.Uuid
  sequenceNumber Int     @unique @default(autoincrement())
  mediaRef       String? @unique // AUR-MED-000001, set after insert

  type            MediaType
  title           String
  description     String?
  storageRef      String
  mimeType        String?
  sizeBytes       Int?
  durationSeconds Int?

  uploadedById String    @db.Uuid
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  courseMedia CourseMedia[]

  @@index([type])
  @@index([uploadedById])
}

model CourseMedia {
  id           String     @id @default(uuid()) @db.Uuid
  courseId     String     @db.Uuid
  course       Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonId     String?    @db.Uuid
  lesson       Lesson?    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  mediaAssetId String     @db.Uuid
  mediaAsset   MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  position     Int        @default(0)
  createdAt    DateTime   @default(now())

  @@index([courseId])
  @@index([lessonId])
  @@index([mediaAssetId])
}

// ===========================================================================
// AI Intelligence Engine  —  Orchestrates the existing Aureus platform for a
// member/steward (PA-006). NOT a general chatbot: every capability is scoped
// to explaining/recommending against real platform data (Journeys,
// Opportunities, Resources, Knowledge, Academy, Stewardship, Business
// Portal). The AI never performs an irreversible action automatically — a
// Recommendation is a suggestion record only; approving one is a status
// flip, not an auto-executed action (ADR-015 Decision 6).
// ===========================================================================

enum AiProvider {
  OPENAI
  ANTHROPIC
  STUB
}

enum AiCapability {
  QUESTION_ANSWERING
  RECOMMENDATION
  OPPORTUNITY_EXPLANATION
  RESOURCE_EXPLANATION
  JOURNEY_GUIDANCE
  ACADEMY_GUIDANCE
  KNOWLEDGE_SEARCH
  POD_INSIGHT
}

enum AiRequestStatus {
  SUCCESS
  FAILED
}

enum AiMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum AiRecommendationStatus {
  PENDING
  ACCEPTED
  DISMISSED
}

// AiConversation / AiMessage  —  Conversation-memory abstraction for AI
// Question Answering. Real FK to User: a genuine per-member record, not an
// audit pointer (mirrors Enrollment/Certification, ADR-014).
model AiConversation {
  id     String  @id @default(uuid()) @db.Uuid
  userId String  @db.Uuid
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages AiMessage[]
  requests AiRequest[]

  @@index([userId])
}

model AiMessage {
  id             String         @id @default(uuid()) @db.Uuid
  conversationId String         @db.Uuid
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           AiMessageRole
  content        String
  createdAt      DateTime       @default(now())

  @@index([conversationId])
}

// AiRequest  —  One row per provider call. Unifies "AI request history,"
// "cost tracking," and "audit logging" into a single ledger, the same
// reasoning as ADR-014 Decision 7's single completion/certification code
// path: they are one event, not three independently-invoked mechanisms.
model AiRequest {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  conversationId String?         @db.Uuid
  conversation   AiConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  capability       AiCapability
  provider         AiProvider
  model            String
  promptTokens     Int
  completionTokens Int
  costUsd          Float
  latencyMs        Int
  status           AiRequestStatus
  errorMessage     String?

  createdAt DateTime @default(now())

  recommendations AiRecommendation[]

  @@index([userId])
  @@index([capability])
  @@index([createdAt])
}

// AiRecommendation  —  A suggestion the AI Engine produced. Real, nullable,
// mutually-exclusive FKs per target type, reusing the StewardshipRecommendation
// precedent (a fixed, small target-type set) rather than a polymorphic loose
// pointer (ADR-015 Decision 5). Approval never triggers an automatic action —
// the member/steward always completes the real action (enroll, save, etc.)
// through the existing domain's own endpoints.
model AiRecommendation {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  opportunityId String?      @db.Uuid
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  resourceId    String?      @db.Uuid
  resource      Resource?    @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  courseId      String?      @db.Uuid
  course        Course?      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  podId         String?      @db.Uuid
  pod           Pod?         @relation(fields: [podId], references: [id], onDelete: Cascade)

  rationale String
  status    AiRecommendationStatus @default(PENDING)
  decidedAt DateTime?

  aiRequestId String?    @db.Uuid
  aiRequest   AiRequest? @relation(fields: [aiRequestId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@index([opportunityId])
  @@index([resourceId])
  @@index([courseId])
  @@index([podId])
}

// ===========================================================================
// Pods System (PA-009, OAS-ACA-009)  —  Aureus's smallest living
// communities. WO-030. "They do not exist to manage people. They exist to
// care for people." (Article I). Every model and enum below carries the 13
// Founder Decisions made during Founder Review — see
// docs/work-orders/WO-030-Pods-Founder-Review-Specification.md for the full
// constitutional reasoning behind each choice.
// ===========================================================================

enum PodType {
  HOME
  INTEREST
}

enum PodStatus {
  FORMING
  ACTIVE
  DORMANT
  ARCHIVED
}

enum PodMemberRole {
  MEMBER
  STEWARD
}

// DECLINED and ENDED are distinct: DECLINED/DEFERRED describe a response to
// an invitation that never became membership; ENDED describes membership
// that concluded. A proactive Home Pod invitation is never automatic
// assignment (Founder Decision #1).
enum PodMembershipStatus {
  PENDING
  ACTIVE
  DECLINED
  DEFERRED
  ENDED
}

enum PodMembershipOrigin {
  MEMBER_REQUEST
  AI_MATCH_SUGGESTION
  STEWARD_INVITATION
  ADMIN_ASSIGNMENT
}

enum PodEventType {
  MEETING
  SERVICE_PROJECT
  CELEBRATION
  OTHER
}

enum PodEventStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum RsvpResponse {
  YES
  NO
  MAYBE
}

enum MeetingCadence {
  WEEKLY
  BIWEEKLY
  MONTHLY
  AD_HOC
}

enum ServiceProjectStatus {
  PROPOSED
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum PodRequestType {
  JOIN
  LEAVE
  REASSIGNMENT
  PROPOSE_NEW_POD
}

enum PodRequestStatus {
  PENDING
  APPROVED
  DECLINED
  WITHDRAWN
}

enum PodInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

// Pod  —  The community itself. PodStatus is intentionally not the shared
// VerificationStatus enum: a Pod is a living group with an operational
// lifecycle, not publishable content with a moderation workflow.
// `parentPodId` is "Stewardship Origin" (Founder Decision #11) — institutional
// memory of faithful multiplication, never hierarchy, ownership, or ranking.
// Every child Pod is a fully independent community from the moment it exists.
model Pod {
  id               String    @id @default(uuid()) @db.Uuid
  sequenceNumber   Int       @unique @default(autoincrement())
  podRef           String?   @unique // AUR-POD-000001, set after insert
  name             String
  shortDescription String
  fullDescription  String
  type             PodType
  status           PodStatus @default(FORMING)
  capacity         Int       @default(12)
  primaryLanguage  String?

  // Coarse local-area signal (Founder Decision #8) — the community area this
  // Pod (especially a HOME Pod) primarily serves, set by its Steward/Admin.
  // Same shape as Profile's member-facing location fields; never precise
  // geolocation. This is what a member's own Profile location is matched
  // against in the deterministic scoring function (§2.3).
  city          String?
  region        String?
  stateProvince String?
  country       String?

  // Column default, never a hardcoded app constant (StewardCapacity
  // precedent) — no PodEvent held within this many days signals DORMANT.
  dormancyThresholdDays Int @default(60)

  // Stewardship Origin (Founder Decision #11) — see model doc-comment.
  parentPodId String? @db.Uuid
  parentPod   Pod?    @relation("PodStewardshipOrigin", fields: [parentPodId], references: [id])
  childPods   Pod[]   @relation("PodStewardshipOrigin")

  createdById String    @db.Uuid
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  members           PodMembership[]
  events            PodEvent[]
  meetingSchedule   PodMeetingSchedule?
  serviceProjects   PodServiceProject[]
  requests          PodRequest[]
  invitations       PodInvitation[]
  escalations       StewardshipEscalation[]
  aiRecommendations AiRecommendation[]
  conversation      Conversation?

  @@index([type])
  @@index([status])
  @@index([parentPodId])
}

// PodMembership  —  Who belongs to which Pod, and how. Mirrors
// StewardshipRelationship's real-FK join-with-lifecycle shape: rows are
// never rewritten, only superseded (ADR-011). AI_MATCH_SUGGESTION always
// lands PENDING — AI may suggest a Pod, it may never finalize a membership
// (ADR-015 Decision 6, extended here for a second domain). A member's Home
// Pod is derived (their one ACTIVE membership where Pod.type = HOME); no
// denormalized field lives on User. "At most one ACTIVE and one PENDING
// membership per (pod, user)" is a service-layer invariant, not a DB
// constraint — the same choice StewardshipRelationship already makes, since
// a DB-level unique on (podId, userId, status) would wrongly block a
// member's second ENDED cycle (join, leave, rejoin, leave again).
model PodMembership {
  id     String @id @default(uuid()) @db.Uuid
  podId  String @db.Uuid
  pod    Pod    @relation(fields: [podId], references: [id], onDelete: Cascade)
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role   PodMemberRole       @default(MEMBER)
  status PodMembershipStatus @default(PENDING)
  origin PodMembershipOrigin

  invitedById String? @db.Uuid

  joinedAt  DateTime?
  endedAt   DateTime?
  endReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([podId])
  @@index([userId])
  @@index([status])
}

// PodEvent  —  A concrete, scheduled gathering with attendance. Kept
// intentionally minimal: OAS-OPS-104 is a facilitation script for the human
// Steward to follow, not data the platform needs to store.
model PodEvent {
  id          String         @id @default(uuid()) @db.Uuid
  podId       String         @db.Uuid
  pod         Pod            @relation(fields: [podId], references: [id], onDelete: Cascade)
  title       String
  description String?
  type        PodEventType   @default(MEETING)
  startsAt    DateTime
  endsAt      DateTime?
  location    String?
  createdById String         @db.Uuid
  status      PodEventStatus @default(SCHEDULED)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  rsvps PodEventRsvp[]

  @@index([podId])
  @@index([startsAt])
}

// PodEventRsvp  —  Upcoming RSVPs are visible to fellow Pod members;
// `attended` (set after the fact by the Steward) is visible only to the
// member themselves, their Steward, and Admins, and is never a performance
// metric anywhere it is surfaced (Founder Decision #5).
model PodEventRsvp {
  id       String       @id @default(uuid()) @db.Uuid
  eventId  String       @db.Uuid
  event    PodEvent     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId   String       @db.Uuid
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  response RsvpResponse @default(MAYBE)
  attended Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, userId])
  @@index([userId])
}

// PodMeetingSchedule  —  The recurring pattern, kept separate from
// individual PodEvent instances. Never auto-generates future PodEvents
// (Founder Decision #10) — instead, its stored defaults (cadence, location,
// durationMinutes) pre-fill the next PodEvent a Steward creates. The
// Steward always reviews, edits as needed, and publishes: "Automation shall
// remove unnecessary administrative burden, but it shall never replace
// intentional stewardship."
model PodMeetingSchedule {
  id              String         @id @default(uuid()) @db.Uuid
  podId           String         @unique @db.Uuid
  pod             Pod            @relation(fields: [podId], references: [id], onDelete: Cascade)
  cadence         MeetingCadence @default(WEEKLY)
  dayOfWeek       Int? // 0-6, null for AD_HOC
  timeOfDay       String? // "19:00" — no timezone-aware scheduling infra exists yet
  location        String?
  durationMinutes Int?
  createdById     String         @db.Uuid
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// PodServiceProject  —  Article IX's "who needs us?" — lightweight, not a
// project-management system. Deliberately no task list, budget, or
// volunteer sign-up matrix.
model PodServiceProject {
  id           String               @id @default(uuid()) @db.Uuid
  podId        String               @db.Uuid
  pod          Pod                  @relation(fields: [podId], references: [id], onDelete: Cascade)
  title        String
  description  String
  status       ServiceProjectStatus @default(PROPOSED)
  proposedById String               @db.Uuid
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([podId])
  @@index([status])
}

// PodRequest  —  A member's request to join, leave, be reassigned, or
// propose a new Pod — Article VIII's "Freedom of Belonging" made concrete.
// Always reviewed, never silently auto-applied. An approved
// PROPOSE_NEW_POD request creates a new Pod{status: FORMING}; per Founder
// Decision #2, its first Steward is institutionally appointed, never
// automatically the proposer.
model PodRequest {
  id     String         @id @default(uuid()) @db.Uuid
  userId String         @db.Uuid
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   PodRequestType

  // Target Pod for JOIN/LEAVE/REASSIGNMENT; null for PROPOSE_NEW_POD.
  podId String? @db.Uuid
  pod   Pod?    @relation(fields: [podId], references: [id], onDelete: Cascade)

  proposedPodName        String?
  proposedPodDescription String?
  reason                 String?

  status      PodRequestStatus @default(PENDING)
  decidedById String?          @db.Uuid
  decidedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([podId])
  @@index([status])
}

// PodInvitation  —  Article IV's "never forced... always invited." Who may
// issue one depends on the target Pod's type (Founder Decision #3): Home
// Pod — Steward/Institution only; Interest Pod — any ACTIVE member.
// Enforced in the service layer against the target Pod's `type`.
model PodInvitation {
  id            String              @id @default(uuid()) @db.Uuid
  podId         String              @db.Uuid
  pod           Pod                 @relation(fields: [podId], references: [id], onDelete: Cascade)
  invitedUserId String              @db.Uuid
  invitedUser   User                @relation("PodInvitationInvitee", fields: [invitedUserId], references: [id], onDelete: Cascade)
  invitedById   String              @db.Uuid
  message       String?
  status        PodInvitationStatus @default(PENDING)
  respondedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([podId])
  @@index([invitedUserId])
  @@index([status])
}

// No PodMetrics model exists by design. Per Article X and the founder's
// non-surveillance instruction, Pod metrics (attendance rate, membership
// size/stability, service-project completion, meeting cadence adherence)
// are computed on read, at the Pod level, from the operational models
// above — never persisted per-member, never a stored score or ranking.
